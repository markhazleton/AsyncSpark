@model Microsoft.AspNetCore.Html.HtmlString
@{
    ViewData["Title"] = "Home Page";
}

<div class="row justify-content-center mb-5">
    <div class="col-lg-10">
        <div class="text-center mb-4">
            <p class="text-body-secondary small mb-1">
                Part of <a href="https://makeboldspark.com" target="_blank" rel="noopener" class="link-secondary">Make Bold Spark</a>
                &mdash; technical demonstrations by <a href="https://markhazleton.com" target="_blank" rel="noopener" class="link-secondary">Mark Hazleton</a>,
                <a href="https://makeboldsolutions.com" target="_blank" rel="noopener" class="link-secondary">Make Bold Solutions</a>
            </p>
        </div>
        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold mb-3">
                <i class="bi bi-lightning-charge-fill me-2 icon-pulse"></i>Master Async/Await in C#
            </h1>
            <p class="lead">
                Learn async programming through interactive examples, real-world scenarios, and hands-on API exploration
            </p>
            <div class="mt-4">
                <a href="/home/learn" class="btn btn-lg btn-primary me-3">
                    <i class="bi bi-mortarboard-fill me-2"></i>Start Learning
                </a>
                <a href="/scalar/v1" class="btn btn-lg btn-outline-secondary">
                    <i class="bi bi-braces me-2"></i>Try the API
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-lg-10">
        <div class="card shadow-sm p-4">
            <div class="card-header bg-transparent border-0 mb-3">
                <h3 class="mb-0 d-flex align-items-center">
                    <i class="bi bi-file-earmark-text me-2 text-primary"></i>
                    <span>AsyncSpark Documentation</span>
                </h3>
            </div>
            <div class="card-body">
                @Html.Raw(Model)
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-5 justify-content-center">
    <div class="col-lg-10">
        <h2 class="text-center mb-4">
            What You'll Learn
        </h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 p-4">
                    <div class="d-inline-block p-3 rounded-circle mb-3 bg-primary bg-opacity-10">
                        <i class="bi bi-shield-shaded fs-1 text-primary"></i>
                    </div>
                    <h4>Resilience Patterns</h4>
                    <p class="mb-3">Master retry policies, circuit breakers, and timeout handling using Polly.</p>
                    <ul class="list-unstyled small mb-4">
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Exponential backoff with jitter</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Handling transient failures</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Production-ready error handling</li>
                    </ul>
                    <a href="/polly" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-arrow-right-circle me-1"></i> Try Polly Demo
                    </a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 p-4">
                    <div class="d-inline-block p-3 rounded-circle mb-3 bg-secondary bg-opacity-10">
                        <i class="bi bi-stopwatch fs-1 text-secondary"></i>
                    </div>
                    <h4>Cancellation & Timeouts</h4>
                    <p class="mb-3">Understand how to properly cancel operations and implement timeouts.</p>
                    <ul class="list-unstyled small mb-4">
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>CancellationToken patterns</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Linked token sources</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Resource cleanup on cancel</li>
                    </ul>
                    <a href="/home/learn#module2" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-mortarboard me-1"></i> Learn Module
                    </a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 p-4">
                    <div class="d-inline-block p-3 rounded-circle mb-3 bg-danger bg-opacity-10">
                        <i class="bi bi-lightning fs-1 text-danger"></i>
                    </div>
                    <h4>Parallel Execution</h4>
                    <p class="mb-3">Learn Task.WhenAll and SemaphoreSlim for efficient concurrency.</p>
                    <ul class="list-unstyled small mb-4">
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Sequential vs. parallel comparison</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Throttling with semaphores</li>
                        <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Performance optimization</li>
                    </ul>
                    <a href="/bulkcalls" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-arrow-right-circle me-1"></i> Try Bulk Demo
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-5 justify-content-center">
    <div class="col-lg-10">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card p-4 h-100">
                    <div class="d-flex align-items-center mb-4">
                        <i class="bi bi-code-slash fs-1 me-3 text-primary"></i>
                        <h3 class="mb-0">API Documentation</h3>
                    </div>
                    <p class="lead mb-4">
                        Explore the API endpoints available in this demo application through our beautiful Scalar API documentation.
                    </p>
                    <a href="/scalar/v1" class="btn btn-primary">
                        <i class="bi bi-braces me-1"></i> View API Docs
                    </a>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card p-4 h-100">
                    <div class="d-flex align-items-center mb-4">
                        <i class="bi bi-palette fs-1 me-3 text-primary"></i>
                        <h3 class="mb-0">Theme Switcher</h3>
                    </div>
                    <p class="mb-3">
                        This application features a dynamic theme system powered by
                        <a href="https://www.nuget.org/packages/WebSpark.Bootswatch" target="_blank" rel="noopener">WebSpark.Bootswatch</a>
                        &mdash; a NuGet package by <a href="https://markhazleton.com" target="_blank" rel="noopener">Mark Hazleton</a>
                        that wraps <a href="https://bootswatch.com/" target="_blank" rel="noopener">Bootswatch</a> themes for ASP.NET Core.
                    </p>
                    <p class="mb-3">
                        Click the theme button in the navigation bar to switch between 25+ professionally designed themes in real time. Your preference is saved automatically via cookie.
                    </p>
                    <a href="/home/webspark" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-box-seam-fill me-1"></i>View WebSpark NuGet Packages
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
